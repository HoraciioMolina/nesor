{
  "name": "nesor-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Nesor — Prisma generator for clean, modular TypeScript domain entities.",
  "license": "MIT",
  "author": "Horacio Molina <horaciiomolina@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoraciioMolina/nesor.git"
  },
  "homepage": "https://github.com/HoraciioMolina/nesor#readme",
  "bugs": "https://github.com/HoraciioMolina/nesor/issues",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@10.0.0"
}
